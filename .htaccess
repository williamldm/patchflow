# ════════════════════════════════════════════════════════════════════
#  Cache — objectif : un déploiement est visible IMMÉDIATEMENT après un
#  simple rechargement, sans avoir à ouvrir une fenêtre privée.
#
#  Principe : le HTML (petit) n'est jamais mis en cache → le navigateur
#  récupère toujours la dernière version, qui pointe vers les assets
#  versionnés (pf-app.js?v=N / pf-app.css?v=N). Les assets, eux, sont
#  mis en cache très longtemps SANS risque : quand on change le JS/CSS,
#  on incrémente ?v=N, l'URL change, donc le navigateur re-télécharge.
# ════════════════════════════════════════════════════════════════════

<IfModule mod_headers.c>
  # HTML : toujours revalider auprès du serveur avant de réutiliser.
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
    Header unset Expires
  </FilesMatch>

  # JS / CSS : versionnés via ?v=N → cache long, immuable.
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# mod_pagespeed (o2switch) : ne pas réécrire nos en-têtes de cache, pour
# que le HTML reste bien non-mis-en-cache. Bloc ignoré si le module est
# absent (donc sans risque).
<IfModule pagespeed_module>
  ModPagespeedModifyCachingHeaders off
</IfModule>
